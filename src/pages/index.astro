---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
	<style>
		/* ── Hero ── */
		.hero {
			position: relative;
			min-height: 520px;
			display: flex;
			align-items: center;
			overflow: hidden;
			background: var(--black-deep);
		}
		.hero .container {
			display: flex;
			justify-content: center;
		}
		.hero__bg {
			position: absolute;
			inset: 0;
			background-image: url('/hero_bg.jpeg');
			background-size: cover;
			background-position: center;
			filter: brightness(0.38);
		}
		.hero__inner {
			position: relative;
			padding: 100px 0 80px;
			max-width: 680px;
			margin: 0 auto;
			text-align: center;
		}
		.hero__label {
			display: inline-block;
			font-size: 11px;
			font-weight: 600;
			letter-spacing: 0.2em;
			text-transform: uppercase;
			color: var(--gold-light, #D4A843);
			margin-bottom: 18px;
			border: 1px solid rgba(184,132,30,0.4);
			padding: 5px 14px;
			border-radius: 20px;
		}
		.hero h1 {
			font-family: var(--font-display),serif;
			font-size: clamp(32px, 5vw, 56px);
			color: var(--white);
			margin-bottom: 20px;
			line-height: 1.1;
		}
		.hero__sub {
			font-size: 16px;
			color: rgba(255,255,255,0.72);
			margin-bottom: 36px;
			line-height: 1.6;
			max-width: 520px;
			margin-left: auto;
			margin-right: auto;
		}
		.hero__actions { display: flex; gap: 14px; flex-wrap: wrap; justify-content: center; }

		/* ── Trust bar ── */
		.trust-bar {
			background: var(--white);
			border-bottom: 1px solid var(--cream-border);
			padding: 24px 0;
			box-shadow: var(--shadow);
		}
		.trust-bar__items {
			display: flex;
			justify-content: center;
			gap: 48px;
			flex-wrap: wrap;
		}
		.trust-item {
			display: flex;
			flex-direction: column;
			align-items: center;
			text-align: center;
			gap: 4px;
		}
		.trust-item__icon { font-size: 22px; }
		.trust-item__label {
			font-size: 11px;
			font-weight: 600;
			letter-spacing: 0.08em;
			text-transform: uppercase;
			color: var(--grey-body);
			opacity: 0.6;
		}
		.trust-item__value {
			font-size: 17px;
			font-weight: 600;
			color: var(--black-deep);
		}

		/* ── Over ons sectie ── */
		.about-section {
			padding: 96px 0;
			background: var(--cream);
		}
		.about-grid {
			display: grid;
			grid-template-columns: 1fr 1.1fr;
			gap: 64px;
			align-items: center;
		}
		.about-logo {
			display: flex;
			justify-content: center;
			align-items: center;
			background: var(--white);
			border: 1px solid var(--cream-border);
			border-radius: 12px;
			padding: 48px;
			box-shadow: var(--shadow);
		}
		.about-logo img { max-width: 280px; }
		.about-content .section-label { color: var(--gold); text-align: center;  }
		.about-content h2 {
			font-size: clamp(24px, 3vw, 36px);
			margin-bottom: 20px;
		}
		.about-content p {
			margin-bottom: 16px;
			font-size: 15px;
			line-height: 1.75;
		}

		/* ── Diensten ── */
		.services-section {
			padding: 96px 0;
			background: var(--white-soft);
		}
		.services-header { text-align: center; margin-bottom: 56px; }
		.services-header h2 { font-size: clamp(24px, 3vw, 36px); margin-bottom: 12px; }
		.services-header p { margin: 0 auto; font-size: 15px; color: var(--grey-body); }

		.services-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 24px;
		}
		.service-card {
			background: var(--white);
			border: 1px solid var(--cream-border);
			border-radius: 10px;
			overflow: hidden;
			box-shadow: var(--shadow);
			transition: transform 0.25s, box-shadow 0.25s;
		}
		.service-card:hover {
			transform: translateY(-4px);
			box-shadow: var(--shadow-lg);
		}
		.service-card__img {
			height: 200px;
			background: var(--cream);
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 48px;
			overflow: hidden;
		}
		.service-card__img img { width: 100%; height: 100%; object-fit: cover; }
		.service-card__body { padding: 24px; }
		.service-card__num {
			font-size: 11px;
			font-weight: 700;
			letter-spacing: 0.1em;
			color: var(--gold);
			margin-bottom: 8px;
		}
		.service-card h3 {
			font-size: 18px;
			margin-bottom: 10px;
		}
		.service-card p { font-size: 14px; color: var(--grey-body); line-height: 1.6; }
		.service-card__link {
			display: inline-block;
			margin-top: 16px;
			font-size: 13px;
			font-weight: 600;
			color: var(--gold);
			letter-spacing: 0.04em;
		}
		.service-card__link:hover { color: var(--gold-hover); }

		/* ── Waarden ── */
		.values-section {
			padding: 96px 0;
			background: var(--cream);
		}
		.values-header { text-align: center; margin-bottom: 56px; }
		.values-header h2 { font-size: clamp(22px, 3vw, 34px); margin-bottom: 10px; }
		.values-grid {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			gap: 24px;
		}
		.value-card {
			background: var(--white);
			border: 1px solid var(--cream-border);
			border-radius: 10px;
			padding: 32px 28px;
			text-align: center;
		}
		.value-card__num {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			width: 40px; height: 40px;
			border-radius: 50%;
			background: rgba(184,132,30,0.12);
			color: var(--gold);
			font-weight: 700;
			font-size: 16px;
			margin-bottom: 16px;
		}
		.value-card h3 { font-size: 17px; margin-bottom: 10px; }
		.value-card p { font-size: 14px; line-height: 1.65; }

		/* ── Review ── */
		.review-section {
			padding: 72px 0;
			background: var(--white-soft);
			text-align: center;
		}
		.review-card {
			max-width: 640px;
			margin: 0 auto;
			background: var(--white);
			border: 1px solid var(--cream-border);
			border-radius: 12px;
			padding: 40px 48px;
			box-shadow: var(--shadow);
		}
		.stars { font-size: 22px; margin-bottom: 16px; color: var(--gold); }
		.review-text {
			font-size: 16px;
			font-style: italic;
			color: var(--grey-body);
			line-height: 1.7;
			margin-bottom: 20px;
		}
		.review-author {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 12px;
			font-size: 14px;
			font-weight: 600;
			color: var(--black-deep);
		}
		.review-avatar {
			width: 40px; height: 40px;
			border-radius: 50%;
			background: var(--gold);
			color: var(--white);
			display: flex;
			align-items: center;
			justify-content: center;
			font-weight: 700;
		}

		@media (max-width: 768px) {
			.about-grid { grid-template-columns: 1fr; }
			.services-grid { grid-template-columns: 1fr; }
			.values-grid { grid-template-columns: 1fr; }
			.trust-bar__items { gap: 24px; }
		}
	</style>

	<!-- Hero -->
	<section class="hero">
		<div class="hero__bg"></div>
		<div class="container">
			<div class="hero__inner">
				<span class="hero__label">Omheind door vertrouwen</span>
				<h1>Hekwerkoplossingen op maat gemaakt</h1>
				<p class="hero__sub">Hoogwaardige en duurzame hekwerken voor zowel particulieren als bedrijven. Vakmanschap en precisie in elk project.</p>
				<div class="hero__actions">
					<a href="/offerte" class="btn btn-gold">Vraag vrijblijvend advies</a>
					<a href="/diensten" class="btn btn-outline" style="color:var(--white);border-color:rgba(255,255,255,0.4);">Bekijk diensten</a>
				</div>
			</div>
		</div>
	</section>

	<!-- Trust bar -->
	<div class="trust-bar">
		<div class="container">
			<div class="trust-bar__items">
				<div class="trust-item">
					<span class="trust-item__icon">📞</span>
					<span class="trust-item__label">Telefonisch bereikbaar op</span>
					<span class="trust-item__value"><a href="tel:0640116418">0640116418</a></span>
				</div>
				<div class="trust-item">
					<span class="trust-item__icon">⭐</span>
					<span class="trust-item__label">5-sterren</span>
					<span class="trust-item__value">100% klanttevredenheid</span>
				</div>
				<div class="trust-item">
					<span class="trust-item__icon">🛠️</span>
					<span class="trust-item__label">Jarenlange</span>
					<span class="trust-item__value">Vakmanschap & precisie</span>
				</div>
			</div>
		</div>
	</div>

	<!-- Over ons -->
	<section class="about-section">
		<div class="container">
			<div class="about-grid">
				<div class="intro-logo-wrap">
					<img src="/logo.png" alt="Hekwerkmeesters logo" />
				</div>
				<div class="about-content">
					<span class="section-label">Wie is Hekwerkmeesters?</span>
					<h2>Jarenlange ervaring en vakmanschap</h2>
					<p>Hekwerkmeesters is een gespecialiseerd hekwerkbedrijf met jaren ervaring in het plaatsen van hekwerken. Wij leveren hoogwaardige en duurzame oplossingen voor zowel particulieren als bedrijven.</p>
					<p>Opgericht vanuit passie voor het vak, staat kwaliteit bij ons voorop. Elk project behandelen wij met de zorg en aandacht die het verdient.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Diensten -->
	<section class="services-section">
		<div class="container">
			<div class="services-header">
				<span class="section-label">Onze diensten</span>
				<h2>Kwaliteitsdiensten voor uw hekwerkbehoeften</h2>
				<p>Van gaashekwerk tot sierhekwerken — wij bieden het complete pakket voor elk type project.</p>
			</div>
			<div class="services-grid">
				<div class="service-card">
					<div class="service-card__img"><img src="/gaashekwerk_2.jpeg" alt="Foto gaashekwerk" /></div>
					<div class="service-card__body">
						<p class="service-card__num">01.</p>
						<h3>Gaashekwerk</h3>
						<p>Duurzaam en functioneel. Ideaal voor tuinen, scholen en bedrijfspercelen — zorgt voor veilige omheining.</p>
						<a href="/diensten" class="service-card__link">Meer informatie →</a>
					</div>
				</div>
				<div class="service-card">
					<div class="service-card__img"><img src="/dubbelstaaf_hekwerk.jpeg" alt="Foto Dubbelstaafmat hekwerk" /></div>
					<div class="service-card__body">
						<p class="service-card__num">02.</p>
						<h3>Dubbelstaafmat hekwerk</h3>
						<p>Sterk en visueel aantrekkelijk. Uitstekende bescherming, geschikt voor zowel industriële als particuliere toepassingen.</p>
						<a href="/diensten" class="service-card__link">Meer informatie →</a>
					</div>
				</div>
				<div class="service-card">
					<div class="service-card__img"><img src="/spijlhekwerk.png" alt="Foto Spijlhekwerk" /></div>
					<div class="service-card__body">
						<p class="service-card__num">03.</p>
						<h3>Spijlhekwerk</h3>
						<p>Veiligheid gecombineerd met een open, moderne uitstraling. Vervaardigd van verzinkt staal met duurzame poedercoating.</p>
						<a href="/diensten" class="service-card__link">Meer informatie →</a>
					</div>
				</div>
				<div class="service-card">
					<div class="service-card__img"><img src="/draaipoort.jpeg" alt="Foto Draaipoort" /></div>
					<div class="service-card__body">
						<p class="service-card__num">03.</p>
						<h3>Draaipoorten</h3>
						<p>Veiligheid gecombineerd met een open, moderne uitstraling. Vervaardigd van verzinkt staal met duurzame poedercoating.</p>
						<a href="/diensten" class="service-card__link">Meer informatie →</a>
					</div>
				</div>
			</div>
			<!--<div style="text-align:center;margin-top:40px;">-->
			<!--	<a href="/diensten" class="btn btn-gold">Alle diensten bekijken</a>-->
			<!--</div>-->
		</div>
	</section>

	<!-- Waarden -->
	<section class="values-section">
		<div class="container">
			<div class="values-header">
				<span class="section-label">Wat ons onderscheidt</span>
				<h2>Onze toewijding aan vakmanschap en klanttevredenheid</h2>
			</div>
			<div class="values-grid">
				<div class="value-card">
					<div class="value-card__num">01</div>
					<h3>Expertise</h3>
					<p>Jarenlange ervaring gegarandeerd voor kwaliteitsresultaten bij elk project dat we aannemen.</p>
				</div>
				<div class="value-card">
					<div class="value-card__num">02</div>
					<h3>Duurzaamheid</h3>
					<p>Gebruik van materialen van hoge kwaliteit voor langdurige hekwerkoplossingen die aan alle verwachtingen voldoen.</p>
				</div>
				<div class="value-card">
					<div class="value-card__num">03</div>
					<h3>Klantenservice</h3>
					<p>Bij Hekwerkmeesters staat u als klant centraal. Persoonlijke service en altijd bereikbaar voor al uw vragen.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Testimonial -->
	<section class="review-section">
		<div class="container">
			<span class="section-label">Tevreden klanten</span>
			<h2 style="font-size:clamp(22px,3vw,32px);margin-bottom:36px;">Wat onze klanten zeggen</h2>
			<div class="review-card">
				<div class="stars">★★★★★</div>
				<p class="review-text">"Hekwerkmeesters heeft ons hek perfect geplaatst! We zijn zeer tevreden met de afgesproken service en kwaliteit. Zeker een aanrader!"</p>
				<div class="review-author">
					<div class="review-avatar">J</div>
					<span>John</span>
				</div>
			</div>
		</div>
	</section>

	<!-- CTA Banner -->
	<div class="cta-banner">
		<div class="container">
			<div class="cta-banner__inner">
				<span class="section-label">Benieuwd naar de prijs?</span>
				<h2>Neem nu contact met ons op voor een<br />vrijblijvende offerte</h2>
				<a href="/offerte" class="btn btn-gold">Vraag een offerte aan</a>
			</div>
		</div>
	</div>

</Layout>